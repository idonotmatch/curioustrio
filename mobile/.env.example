# Copy this file to .env and fill in values for local development.
# Production values are injected at EAS build time via eas.json — do not commit .env.

# API server URL
# - iOS Simulator: http://127.0.0.1:3002 if you use api/.env as-is
# - The mobile client also falls back to local 3001 and 3002 when this is unset
# - Physical device on local network: http://<your-mac-LAN-ip>:3002
#   Find your IP with: ipconfig getifaddr en0
# - Production: set in eas.json, do not set here
EXPO_PUBLIC_API_URL=http://127.0.0.1:3002

# Supabase (get from Supabase dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth client IDs (get from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
