DATABASE_URL=postgres://user:password@localhost:5432/expense_tracker

# Supabase — required for JWT verification on every authenticated request.
# SUPABASE_PROJECT_REF is the subdomain of your Supabase project URL:
#   e.g. https://qybozqtugexupxqavtjj.supabase.co → project ref = qybozqtugexupxqavtjj
# Without this, the JWKS URI resolves to https://undefined.supabase.co/...
# and every API call returns 401, silently logging the user out on mobile.
SUPABASE_PROJECT_REF=your-project-ref

ANTHROPIC_API_KEY=sk-ant-...
PORT=3001

# Apple MapKit Web Services — required for places search (/places/search)
APPLE_MAPS_KEY_ID=your-key-id
APPLE_MAPS_TEAM_ID=your-team-id
APPLE_MAPS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
